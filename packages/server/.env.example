# Postgres connection string used by drizzle and the running server
DATABASE_URL=postgres://plootunes:plootunes@localhost:5432/plootunes

# Port the Express server listens on
PORT=3000

# Secret used to sign the session cookie — set a long random value in prod
SESSION_SECRET=changeme

# Authentik OIDC (auth is disabled unless ISSUER/CLIENT_ID/CLIENT_SECRET are all set)
OIDC_ISSUER=https://auth.plootopia.com/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Authentik's per-app discovery URL returns a global issuer, so this redirects the
# discovery fetch to the per-app URL while still validating against OIDC_ISSUER.
# Only needed if Authentik "global" discovery mode is disabled.
OIDC_DISCOVERY_URL=https://auth.plootopia.com/application/o/plootunes-dev/.well-known/openid-configuration
OIDC_REDIRECT_URI=https://localhost:5173/auth/callback

# Auth bypass for local/e2e testing only — throws on startup if NODE_ENV=production.
# NEVER enable this in production.
PLOOTUNES_AUTH_BYPASS=false
PLOOTUNES_E2E_USER_ID=00000000-0000-0000-0000-000000000001
