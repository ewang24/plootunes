# Music library on the host — mounted at /library inside the server container.
# Defaults (when unset) to the in-repo stub library for a no-config smoke test.
MEDIA_HOST_DIR=/opt/plootunes/library

# App
PLOOTUNES_PORT=8080

# Database
POSTGRES_DB=plootunes
POSTGRES_USER=plootunes
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://plootunes:changeme@postgres:5432/plootunes

# Auth (Authentik OIDC)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://auth.plootopia.com/
# Set if Authentik global mode is disabled (per-app discovery URL)
OIDC_DISCOVERY_URL=https://auth.plootopia.com/application/o/plootunes-dev/.well-known/openid-configuration
OIDC_REDIRECT_URI=https://localhost:5173/auth/callback
SESSION_SECRET=changeme

# Cover art storage (served statically by the server)
COVERS_PUBLIC_PATH=/covers

# Fixed non-root UID/GID the server container runs as — used to chown the
# MEDIA_ROOT host mount so the app is its sole writer in prod
PLOOTUNES_UID=1001
PLOOTUNES_GID=1001
