{
  "name": "physic-octo-rotary-phone",
  "version": "0.0.0",
  "type": "commonjs",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "react": "pnpm -C ./src/react dev",
    "electron": "pnpm -C ./src/electron electron",
    "test": "jest",
    "install:all": "pnpm install && pnpm -C ./src/electron install && pnpm -C ./src/react install",
    "scanFiles": "ts-node ./src/electron/utilityRunners/scanFilesRunner.ts P:/Music/music/rotation/",
    "scanFilesAnyDir": "ts-node ./src/electron/utilityRunners/scanFilesRunner.ts",
    "createTables": "ts-node ./src/core/utilityRunners/tableUtilRunner.ts",
    "clearTables": "ts-node ./src/core/utilityRunners/clearTablesRunner.ts",
    "genTestLibrary": "ts-node ./src/core/db/test/util/testAudioFileGenerator.ts P:/Music/music/rotation",
    "createTestDb": "ts-node ./src/core/db/test/util/createTestDb.ts ../assets/testLibrary",
    "countAudioFiles": "ts-node ./src/core/db/test/util/runCountFiles.ts ../assets/testLibrary",
    "svgr": "npx svgr --out-dir ./src/core/assets/icons/components ./src/core/assets/icons/svgs",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm -F ./packages/server db:generate",
    "db:migrate": "pnpm -F ./packages/server db:migrate",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,scss}'",
    "app:up": "docker compose -f docker/docker-compose.e2e.yml up --build",
    "app:down": "docker compose -f docker/docker-compose.e2e.yml down -v",
    "test:e2e": "echo 'E2E suite is activated in T13 — the harness is not bootable yet. See e2e/README.md.' && exit 1"
  },
  "private": true,
  "dependencies": {
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.5.3",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "music-metadata": "^7.14.0",
    "node-id3": "^0.2.6",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "react": "^18.2.0",
    "sass": "^1.75.0",
    "sass-loader": "^14.2.1",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
